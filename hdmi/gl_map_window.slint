// Raspberry Pi / small-touch-panel layout for the zero-copy GL example.
// Larger touch targets (bigger fonts + a tall toolbar) and a wide right-edge
// vertical zoom strip so taps land reliably on a low-res resistive panel.
import { Button, ComboBox, HorizontalBox, VerticalBox, Slider } from "std-widgets.slint";
import { MMapView, MMapAdapter } from "../src/maplibre.slint";

export { MMapAdapter }

export struct Size {
    width: length,
    height: length,
}

export component MapWindow inherits Window {
    preferred-width: 720px;
    preferred-height: 576px;
    default-font-size: 20px;

    out property<Size> map-size: { width: map.width, height: map.height };
    callback map-size-changed;
    changed map-size => { map-size-changed(); }

    // The ComboBox shows the readable names; selecting one applies the URL at
    // the same index (the two lists are kept parallel).
    property <[string]> style-names: [
        "OSM Bright",
        "OSM Fiord",
        "OSM Bright 日本語",
        "MapTiler Basic 日本語",
        "MapLibre Demo",
    ];
    property <[string]> style-urls: [
        "https://yuiseki.dev/static/styles/osm-bright.json",
        "https://yuiseki.dev/static/styles/osm-fiord.json",
        "https://tile.openstreetmap.jp/styles/osm-bright-ja/style.json",
        "https://tile.openstreetmap.jp/styles/maptiler-basic-ja/style.json",
        "https://demotiles.maplibre.org/style.json",
    ];

    // "Dance" toggle: drives the pitch/bearing animation in the C++ backend.
    in-out property <bool> dancing: false;
    callback set-dance(bool);

    // Keyboard: arrow keys pan, Shift+Up/Down zoom. This FocusScope grabs focus
    // on startup (init below) so the arrows do NOT land on the zoom Slider (which
    // would otherwise consume Up/Down as zoom). Unhandled keys from other widgets
    // bubble up to this ancestor scope, so panning works whatever has focus,
    // except the Slider itself.
    callback pan(/* dx */ float, /* dy */ float);
    init => { keys.focus(); }

    // Staged idle screensaver (driven entirely from C++; see main_gl.cpp).
    //   0 normal  1 DVD logo bounce  2 bouncing map tile  3 off / black
    // The C++ side stops the map render while saver-state > 0 and the opaque
    // overlay below covers the (stale) map texture. NEVER pushed upstream.
    in property <int> saver-state: 0;
    in property <length> logo-x: 40px;
    in property <length> logo-y: 40px;
    in property <brush> logo-color: #5050ff;
    in property <image> tile-image;
    // DVD logo, built in C++ as a hand-tinted SharedPixelBuffer (NOT @image-url,
    // which does not render in this zero-copy GL build).
    in property <image> dvd-image;
    callback wake();

    // The map fills the whole window: the C++ side renders the live map (stage
    // 0) or the composited screensaver frame (black field + bouncing logo/tile)
    // into the FBO this MMapView displays 1:1. The screensaver is NOT drawn with
    // Slint overlay elements: in this zero-copy GL build femtovg only renders
    // the persistent full-screen MMapView's borrowed texture plus plain
    // Rectangles/Text; Image elements (CPU- or GL-backed) inside a conditional
    // overlay do not render at all. The touch controls below float over the map
    // and are hidden while the screensaver runs.
    keys := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.UpArrow) {
                if (event.modifiers.shift) {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, -1);
                } else {
                    root.pan(0, 80);
                }
                return accept;
            }
            if (event.text == Key.DownArrow) {
                if (event.modifiers.shift) {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, 1);
                } else {
                    root.pan(0, -80);
                }
                return accept;
            }
            if (event.text == Key.LeftArrow) { root.pan(80, 0); return accept; }
            if (event.text == Key.RightArrow) { root.pan(-80, 0); return accept; }
            return reject;
        }

        map := MMapView {
            x: 0px;
            y: 0px;
            width: 100%;
            height: 100%;
            style-url: "https://yuiseki.dev/static/styles/osm-bright.json";
            center-lat: 0;
            center-lon: 0;
            zoom: 1;
        }

        // Floating touch controls over the map; hidden during the screensaver.
        Rectangle {
            width: 100%;
            height: 100%;
            background: transparent;
            visible: root.saver-state == 0;

            // Toolbar (top): style dropdown + quick city jumps. Full width
            // (the zoom strip sits below it on the right).
            HorizontalBox {
                x: 22px;
                y: 10px;
                width: parent.width - 44px;
                height: 64px;
                spacing: 8px;
                ComboBox {
                    horizontal-stretch: 2;
                    model: root.style-names;
                    current-index: 0;
                    selected => { map.style-url = root.style-urls[self.current-index]; }
                }
                Button { horizontal-stretch: 1; text: "Paris"; clicked => { map.fly-to(48.8566, 2.3522, 10); } }
                Button { horizontal-stretch: 1; text: "New York"; clicked => { map.fly-to(40.7128, -74.0060, 10); } }
                Button { horizontal-stretch: 1; text: "Tokyo"; clicked => { map.fly-to(35.6895, 139.6917, 10); } }
            }

            // Wide right-edge vertical zoom strip (easy to hit on resistive
            // touch), below the full-width toolbar.
            VerticalBox {
                width: 120px;
                x: parent.width - 128px;
                y: 84px;
                height: parent.height - 96px;
                padding: 8px;
                spacing: 10px;
                Button {
                    min-height: 56px;
                    text: "+";
                    clicked => { MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, -1); }
                }
                Slider {
                    orientation: vertical;
                    vertical-stretch: 1;
                    minimum: 1;
                    maximum: 18;
                    value: 10;
                    changed value => { map.set-zoom(self.value); }
                }
                Button {
                    min-height: 56px;
                    text: "-";
                    clicked => { MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, 1); }
                }
            }

            // Dance/Calm toggle (bottom-left). Kept well inside the bottom and
            // left edges (resistive dead zones) with a large hit target, so a
            // slightly-off tap does not fall through to the map's pan handler.
            Button {
                x: 24px;
                y: parent.height - self.height - 44px;
                min-width: 150px;
                min-height: 64px;
                text: root.dancing ? "Calm" : "Dance";
                clicked => {
                    root.dancing = !root.dancing;
                    root.set-dance(root.dancing);
                }
            }
        }
    } // keys (FocusScope)


    // Screensaver. Hard-won rendering rules for this zero-copy GL + femtovg
    // build (all verified by glReadPixels, not eyeballing):
    //   * The black field is a Rectangle gated with `if` (Rectangles created at
    //     runtime render fine).
    //   * The bouncing IMAGES must be ALWAYS present (an Image created when an
    //     `if` flips true at runtime never uploads its texture and stays blank),
    //     gated with `opacity`, and placed AFTER the overlay so they draw on top.
    if root.saver-state > 0 : Rectangle {
        width: 100%;
        height: 100%;
        background: black;
        TouchArea {
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) { root.wake(); }
            }
        }
    }
    // Stage 1: DVD logo (PNG loaded in C++ via load_from_path).
    Image {
        opacity: root.saver-state == 1 ? 1.0 : 0.0;
        x: root.logo-x;
        y: root.logo-y;
        width: 140px;
        height: 84px;
        source: root.dvd-image;
        image-fit: contain;
    }
    // Stage 2: a 220x220 pre-rendered map tile (mbgl-render PNG, loaded in C++).
    Image {
        opacity: root.saver-state == 2 ? 1.0 : 0.0;
        x: root.logo-x;
        y: root.logo-y;
        width: 220px;
        height: 220px;
        source: root.tile-image;
        image-fit: fill;
    }
}
