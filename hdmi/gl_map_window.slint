// Raspberry Pi / small-touch-panel layout for the zero-copy GL example.
// Larger touch targets (bigger fonts + a tall toolbar) and a wide right-edge
// vertical zoom strip so taps land reliably on a low-res resistive panel.
import { Button, ComboBox, HorizontalBox, VerticalBox, Slider } from "std-widgets.slint";
import { MMapView, MMapAdapter } from "../src/maplibre.slint";

export { MMapAdapter }

export struct Size {
    width: length,
    height: length,
}

export component MapWindow inherits Window {
    preferred-width: 720px;
    preferred-height: 576px;
    default-font-size: 20px;

    out property<Size> map-size: { width: map.width, height: map.height };
    callback map-size-changed;
    changed map-size => { map-size-changed(); }

    property <[string]> style-urls: [
        "https://yuiseki.dev/static/styles/osm-bright.json",
        "https://yuiseki.dev/static/styles/osm-fiord.json",
        "https://tile.openstreetmap.jp/styles/osm-bright-ja/style.json",
        "https://tile.openstreetmap.jp/styles/maptiler-basic-ja/style.json",
        "https://demotiles.maplibre.org/style.json",
    ];

    // "Dance" toggle: drives the pitch/bearing animation in the C++ backend.
    in-out property <bool> dancing: false;
    callback set-dance(bool);

    // Keyboard: arrow keys pan, Shift+Up/Down zoom. This FocusScope grabs focus
    // on startup (init below) so the arrows do NOT land on the zoom Slider (which
    // would otherwise consume Up/Down as zoom). Unhandled keys from other widgets
    // bubble up to this ancestor scope, so panning works whatever has focus,
    // except the Slider itself.
    callback pan(/* dx */ float, /* dy */ float);
    init => { keys.focus(); }

    keys := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.UpArrow) {
                if (event.modifiers.shift) {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, -1);
                } else {
                    root.pan(0, 80);
                }
                return accept;
            }
            if (event.text == Key.DownArrow) {
                if (event.modifiers.shift) {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, 1);
                } else {
                    root.pan(0, -80);
                }
                return accept;
            }
            if (event.text == Key.LeftArrow) { root.pan(80, 0); return accept; }
            if (event.text == Key.RightArrow) { root.pan(-80, 0); return accept; }
            return reject;
        }

    // Outer margin: resistive panels have a dead zone at the very edges, so
    // keep all interactive controls inset from the screen border.
    HorizontalBox {
        padding: 22px;
        // The very top edge of this resistive panel has a wider dead zone, so
        // inset the top further to keep the toolbar reliably tappable.
        padding-top: 48px;
        spacing: 10px;

        VerticalBox {
            horizontal-stretch: 1;
            padding: 0px;
            spacing: 6px;

            HorizontalBox {
                min-height: 64px;
                max-height: 64px;
                spacing: 8px;
                ComboBox {
                    horizontal-stretch: 2;
                    model: root.style-urls;
                    selected(url) => { map.style-url = url; }
                }
                Button {
                    horizontal-stretch: 1;
                    text: "Paris";
                    clicked => { map.fly-to(48.8566, 2.3522, 10); }
                }
                Button {
                    horizontal-stretch: 1;
                    text: "NY";
                    clicked => { map.fly-to(40.7128, -74.0060, 10); }
                }
                Button {
                    horizontal-stretch: 1;
                    text: "Tokyo";
                    clicked => { map.fly-to(35.6895, 139.6917, 10); }
                }
            }

            // Map area with a floating Dance/Calm button at the bottom-left.
            Rectangle {
                vertical-stretch: 1;

                map := MMapView {
                    width: 100%;
                    height: 100%;
                    style-url: "https://yuiseki.dev/static/styles/osm-bright.json";
                    center-lat: 0;
                    center-lon: 0;
                    zoom: 1;
                }

                Button {
                    x: 8px;
                    y: parent.height - self.height - 8px;
                    min-height: 52px;
                    text: root.dancing ? "Calm" : "Dance";
                    clicked => {
                        root.dancing = !root.dancing;
                        root.set-dance(root.dancing);
                    }
                }
            }
        }

        // Wide right-edge vertical zoom strip (easy to hit on resistive touch).
        VerticalBox {
            horizontal-stretch: 0;
            min-width: 120px;
            max-width: 120px;
            padding: 8px;
            spacing: 10px;

            Button {
                min-height: 56px;
                text: "+";
                clicked => {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, -1);
                }
            }
            Slider {
                orientation: vertical;
                vertical-stretch: 1;
                minimum: 1;
                maximum: 18;
                value: 10;
                changed value => { map.set-zoom(self.value); }
            }
            Button {
                min-height: 56px;
                text: "-";
                clicked => {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, 1);
                }
            }
        }
    }
    } // keys (FocusScope)
}
