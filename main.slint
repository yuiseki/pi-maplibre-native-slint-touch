import { Button, VerticalBox, ComboBox, HorizontalBox } from "std-widgets.slint";
import { MMapView, MMapAdapter } from "src/ui/maplibre.slint";

export { MMapAdapter }

export struct Size {
    width: length,
    height: length,
}

export component MapWindow inherits Window {
    // Native size of the target SPI panel (Osoyoo 3.5B, 480x320).
    preferred-width: 480px;
    preferred-height: 320px;
    default-font-size: 16px;

    out property <Size> map-size: { width: map.width, height: map.height };
    callback map-size-changed;
    changed map-size => { map-size-changed(); }

    // --- screensaver (driven from Rust) ---
    // 0 = normal, 1 = DVD logo bounce, 2 = bouncing map tile, 3 = off (black)
    in property <int> saver-state: 0;
    in property <length> logo-x: 40px;
    in property <length> logo-y: 40px;
    in property <brush> logo-color: #4af;
    in property <image> tile-image;          // captured map crop for stage 2
    in property <bool> map-render-active: true; // gate for the MMapView render loop
    callback wake();

    // Style list shown in the dropdown. Rust prepends MAPLIBRE_STYLE_URL when set.
    in-out property <[string]> style-urls: [
        "https://demotiles.maplibre.org/style.json",
        "https://tile.openstreetmap.jp/styles/osm-bright/style.json",
    ];
    // Currently selected style (defaults to the first list entry).
    property <string> current-style: root.style-urls[0];

    // Pi / small resistive-touch-panel layout (480x320 native).
    //
    // Tuned for a slow SPI panel and single-touch resistive input:
    //   - Large touch targets (bigger font, tall toolbar, wide zoom strip).
    //   - An outer margin, because resistive panels have a dead zone at the
    //     very edge where taps do not register.
    //   - NO flyTo animation and NO stepless zoom slider: the software renderer
    //     on this panel is slow, so camera moves are instant jumps (this repo's
    //     `fly-to` already jumps, it does not animate) and zoom is stepped via
    //     +/- buttons (each press is one discrete `wheel-zoomed` step).
    //   - No Pitch/Bearing sliders (not useful at this size, and they cost taps).
    HorizontalBox {
        padding: 14px;
        spacing: 10px;

        VerticalBox {
            horizontal-stretch: 1;
            padding: 0px;
            spacing: 6px;

            HorizontalBox {
                min-height: 48px;
                max-height: 48px;
                spacing: 6px;
                ComboBox {
                    horizontal-stretch: 2;
                    model: root.style-urls;
                    current-index: 0;
                    selected(url) => { root.current-style = url; }
                }
                Button {
                    horizontal-stretch: 1;
                    text: "Paris";
                    clicked => { map.fly-to(48.8566, 2.3522, 10); }
                }
                Button {
                    horizontal-stretch: 1;
                    text: "NY";
                    clicked => { map.fly-to(40.7128, -74.0060, 10); }
                }
                Button {
                    horizontal-stretch: 1;
                    text: "Tokyo";
                    clicked => { map.fly-to(35.6895, 139.6917, 10); }
                }
            }

            map := MMapView {
                style-url: root.current-style;
                center-lat: 0;
                center-lon: 0;
                zoom: 1;
                // Render loop gate, controlled from Rust (off during screensaver,
                // briefly on while a tile is being captured).
                render-active: root.map-render-active;
            }
        }

        // Right-edge vertical zoom strip. Stepped only (no stepless slider):
        // each tap is one `wheel-zoomed` step. delta < 0 zooms in, delta > 0
        // zooms out (see headless.rs `wheel_zoomed`).
        VerticalBox {
            horizontal-stretch: 0;
            min-width: 72px;
            max-width: 72px;
            padding: 0px;
            spacing: 8px;

            Button {
                vertical-stretch: 1;
                text: "+";
                clicked => {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, -1);
                }
            }
            Text {
                text: "Z " + round(map.current-zoom);
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Button {
                vertical-stretch: 1;
                text: "-";
                clicked => {
                    MMapAdapter.wheel-zoomed(map.width / 2 / 1px, map.height / 2 / 1px, 1);
                }
            }
        }
    }

    // Screensaver overlay: covers the whole window when active. Any touch wakes.
    if root.saver-state > 0: Rectangle {
        width: 100%;
        height: 100%;
        background: black;

        TouchArea {
            // Wake on any pointer-down (touch). The Rust evdev watcher is a backstop.
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    root.wake();
                }
            }
        }

        // Bouncing DVD-Video logo while in screensaver state (hidden when "off").
        // colorize tints the logo's alpha silhouette with the current color
        // (classic bouncing-DVD colour change on each bounce).
        if root.saver-state == 1: Image {
            source: @image-url("assets/dvd-logo.png");
            colorize: root.logo-color;
            image-fit: contain;
            x: root.logo-x;
            y: root.logo-y;
            width: 140px;
            height: 84px;
        }

        // Stage 2: bouncing square map tile (random region/style, captured by Rust).
        if root.saver-state == 2: Image {
            source: root.tile-image;
            image-fit: fill;
            x: root.logo-x;
            y: root.logo-y;
            width: 140px;
            height: 140px;
        }
    }
}
